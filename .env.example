# MarketMind AI Dashboard - Environment Variables
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ── LLM: DeepSeek V4 Flash ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Financial Data APIs ──
# Get free key: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here
# Get free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alphavantage_api_key_here

# ── Cache TTL (seconds) ──
CACHE_TTL_PRICE=300
CACHE_TTL_NEWS=1800
CACHE_TTL_FUNDAMENTALS=86400
CACHE_TTL_MACRO=3600

# ── Server ──
HOST=0.0.0.0
PORT=8001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
VITE_API_BASE_URL=http://127.0.0.1:8001/api

# ── Analysis ──
MAX_NEWS_ARTICLES=15
REDDIT_POST_LIMIT=25
AGENT_TIMEOUT=60
MAX_RETRIES=2

# ── Debug ──
LOG_LEVEL=INFO
DEBUG=false
